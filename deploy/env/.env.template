# ===========================================
# E-LEARNING PLATFORM - MASTER CONFIGURATION
# ===========================================
# Этот файл содержит ВСЕ переменные для ВСЕХ сервисов
# Используйте префиксы для избежания конфликтов
# ===========================================

# -------------------------------------------
# CORE INFRASTRUCTURE
# -------------------------------------------

# PostgreSQL
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=elearning
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production

# Redis (для будущего использования)
REDIS_IMAGE=redis:7-alpine
REDIS_HOST=redis
REDIS_PORT=6379

# -------------------------------------------
# AUTH SERVICE
# -------------------------------------------

AUTH_GRPC_HOST=0.0.0.0
AUTH_GRPC_PORT=50051

AUTH_LOGGER_LEVEL=info
AUTH_LOGGER_AS_JSON=false

AUTH_POSTGRES_HOST=${POSTGRES_HOST}
AUTH_POSTGRES_PORT=${POSTGRES_PORT}
AUTH_POSTGRES_DB=${POSTGRES_DB}
AUTH_POSTGRES_SCHEMA=auth
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_pass

AUTH_JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-prod
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=168h

# -------------------------------------------
# USER SERVICE
# -------------------------------------------

USER_GRPC_HOST=0.0.0.0
USER_GRPC_PORT=50052

USER_LOGGER_LEVEL=info
USER_LOGGER_AS_JSON=false

USER_POSTGRES_HOST=${POSTGRES_HOST}
USER_POSTGRES_PORT=${POSTGRES_PORT}
USER_POSTGRES_DB=${POSTGRES_DB}
USER_POSTGRES_SCHEMA=users
USER_POSTGRES_USER=user_user
USER_POSTGRES_PASSWORD=user_pass

# -------------------------------------------
# COURSE SERVICE
# -------------------------------------------

COURSE_GRPC_HOST=0.0.0.0
COURSE_GRPC_PORT=50053

COURSE_LOGGER_LEVEL=info
COURSE_LOGGER_AS_JSON=false

COURSE_POSTGRES_HOST=${POSTGRES_HOST}
COURSE_POSTGRES_PORT=${POSTGRES_PORT}
COURSE_POSTGRES_DB=${POSTGRES_DB}
COURSE_POSTGRES_SCHEMA=courses
COURSE_POSTGRES_USER=course_user
COURSE_POSTGRES_PASSWORD=course_pass

# -------------------------------------------
# API GATEWAY
# -------------------------------------------

GATEWAY_HTTP_HOST=0.0.0.0
GATEWAY_HTTP_PORT=8080

GATEWAY_LOGGER_LEVEL=info
GATEWAY_LOGGER_AS_JSON=false

GATEWAY_AUTH_SERVICE_ADDR=auth-service:50051
GATEWAY_USER_SERVICE_ADDR=user-service:50052
GATEWAY_COURSE_SERVICE_ADDR=course-service:50053

GATEWAY_RATE_LIMIT_REQUESTS=100
GATEWAY_RATE_LIMIT_WINDOW=1m

# -------------------------------------------
# VIDEO SERVICE
# -------------------------------------------

VIDEO_GRPC_HOST=0.0.0.0
VIDEO_GRPC_PORT=50054

VIDEO_LOGGER_LEVEL=info
VIDEO_LOGGER_AS_JSON=false

VIDEO_POSTGRES_HOST=${POSTGRES_HOST}
VIDEO_POSTGRES_PORT=${POSTGRES_PORT}
VIDEO_POSTGRES_DB=${POSTGRES_DB}
VIDEO_POSTGRES_SCHEMA=videos
VIDEO_POSTGRES_USER=video_user
VIDEO_POSTGRES_PASSWORD=video_pass

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

VIDEO_MINIO_ENDPOINT=minio:9000
VIDEO_MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
VIDEO_MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
VIDEO_MINIO_BUCKET=videos
VIDEO_MINIO_USE_SSL=false
VIDEO_MINIO_REGION=

# Video Settings
VIDEO_SIGNED_URL_EXPIRES_SECONDS=7200
