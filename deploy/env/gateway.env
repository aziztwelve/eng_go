# ----------------------------
# API Gateway Configuration
# ----------------------------
# Этот файл генерируется автоматически из .env
# НЕ редактируйте вручную!
# ----------------------------

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Logger
LOGGER_LEVEL=info
LOGGER_AS_JSON=false

# Service Addresses
AUTH_SERVICE_ADDR=auth-service:50051
USER_SERVICE_ADDR=user-service:50052
COURSE_SERVICE_ADDR=course-service:50053

# Rate Limiting (future)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
